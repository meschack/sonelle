{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonelle",
  "version": "0.1.0",
  "identifier": "app.sonelle.reader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sonelle",
        "width": 1240,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/audio/**", "$APPDATA/covers/**", "$APPDATA/narration-v3/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["epub"],
        "mimeType": "application/epub+zip",
        "name": "EPUB book",
        "role": "Viewer",
        "rank": "Default"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "linux/Sonelle.desktop"
      },
      "rpm": {
        "desktopTemplate": "linux/Sonelle.desktop"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
