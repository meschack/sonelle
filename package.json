{
  "name": "sonelle-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:tui": "node scripts/dev-tui.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:desktop": "pnpm --filter @sonelle/desktop tauri dev",
    "dev:web": "pnpm --filter @sonelle/desktop dev",
    "setup:piper": "node scripts/setup-piper-voice.mjs",
    "build": "pnpm --filter @sonelle/desktop build",
    "build:desktop": "pnpm --filter @sonelle/desktop tauri build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:native": "cargo check",
    "qa:real-books": "cargo test real_book_qa_imports_configured_epubs_through_storage_workflow -- --ignored --nocapture",
    "perf:large-books": "cargo test large_book_performance_harness_reports_reader_timings -- --ignored --nocapture",
    "spike:narration:setup": "node scripts/setup-narration-spike.mjs",
    "spike:narration:models": "node scripts/setup-narration-spike.mjs --models",
    "spike:narration:verify": "node scripts/setup-narration-spike.mjs --models --verify-only",
    "spike:narration:kokoro-reference": "node scripts/setup-kokoro-reference.mjs",
    "spike:narration:kokoro-export": "node scripts/setup-kokoro-reference.mjs --export-onnx",
    "spike:narration:kokoro-corpus": "node scripts/setup-kokoro-reference.mjs --corpus",
    "check": "pnpm typecheck && pnpm test && pnpm format",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
